<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Superchat - Business Messaging Platform</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
  <link href="~/css/site.css" rel="stylesheet" />
</head>
<body>
  <nav class="navbar navbar-dark bg-dark border-bottom border-secondary px-3" style="height:56px">
    <a class="navbar-brand fw-bold" href="/"><i class="bi bi-whatsapp me-2 text-success"></i>Superchat</a>
    <div class="d-flex align-items-center gap-2">
      <span id="connBadge" class="badge bg-warning small"><span class="status-dot status-awaiting"></span>...</span>
    </div>
  </nav>

  <div class="app-layout">
    <div class="sidebar-nav">
      <button class="nav-btn active" data-panel="inbox" title="Inbox"><i class="bi bi-chat-dots"></i></button>
      <button class="nav-btn" data-panel="contacts" title="Contacts"><i class="bi bi-people"></i></button>
      <button class="nav-btn" data-panel="campaigns" title="Campaigns"><i class="bi bi-megaphone"></i></button>
      <button class="nav-btn" data-panel="templates" title="Templates"><i class="bi bi-file-text"></i></button>
      <button class="nav-btn" data-panel="workflows" title="Automation"><i class="bi bi-diagram-3"></i></button>
      <button class="nav-btn" data-panel="team" title="Team"><i class="bi bi-people-fill"></i></button>
      <button class="nav-btn" data-panel="analytics" title="Analytics"><i class="bi bi-graph-up"></i></button>
      <button class="nav-btn" data-panel="channels" title="Channels"><i class="bi bi-hdd-stack"></i></button>
      <hr class="w-75 my-1" />
      <button class="nav-btn" data-panel="settings" title="Settings"><i class="bi bi-gear"></i></button>
    </div>

    @RenderBody()
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@@8.0.0/dist/browser/signalr.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@@4.4.7/dist/chart.umd.min.js"></script>
  <script src="~/js/site.js" asp-append-version="true"></script>
  @RenderSection("Scripts", required: false)
</body>
</html>
