<div class="modal fade" id="templateModal" tabindex="-1"><div class="modal-dialog modal-xl"><div class="modal-content">
  <div class="modal-header"><h6 class="modal-title" id="templateBuilderTitle">New Template</h6><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
  <div class="modal-body">
    <input type="hidden" id="tbId" />
    <div class="row">
      <div class="col-md-3 border-end pe-3">
        <div class="mb-3">
          <label class="form-label small fw-bold">Template Name</label>
          <input class="form-control form-control-sm" id="tbName" placeholder="My Template" />
        </div>
        <div class="mb-3">
          <label class="form-label small fw-bold">Category</label>
          <select class="form-select form-select-sm" id="tbCategory"><option value="UTILITY">Utility</option><option value="MARKETING">Marketing</option><option value="AUTHENTICATION">Authentication</option></select>
        </div>
        <div class="mb-3">
          <label class="form-label small fw-bold">Language</label>
          <select class="form-select form-select-sm" id="tbLanguage"><option value="en">English</option><option value="es">Spanish</option><option value="ar">Arabic</option></select>
        </div>
        <hr />
        <div class="mb-2">
          <label class="form-label small fw-bold">Content Type</label>
          <div class="template-type-list" id="tbContentType">
            <div class="template-type-item active" data-type="twilio/text" onclick="selectContentType('twilio/text')"><i class="bi bi-fonts"></i> Text</div>
            <div class="template-type-item" data-type="twilio/media" onclick="selectContentType('twilio/media')"><i class="bi bi-image"></i> Media</div>
            <div class="template-type-item" data-type="twilio/quick-reply" onclick="selectContentType('twilio/quick-reply')"><i class="bi bi-chat-dots"></i> Quick Reply</div>
            <div class="template-type-item" data-type="twilio/call-to-action" onclick="selectContentType('twilio/call-to-action')"><i class="bi bi-box-arrow-up-right"></i> Call to Action</div>
            <div class="template-type-item" data-type="twilio/list-picker" onclick="selectContentType('twilio/list-picker')"><i class="bi bi-list-ul"></i> List Picker</div>
            <div class="template-type-item" data-type="twilio/card" onclick="selectContentType('twilio/card')"><i class="bi bi-credit-card"></i> Card</div>
            <div class="template-type-item" data-type="whatsapp/card" onclick="selectContentType('whatsapp/card')"><i class="bi bi-whatsapp"></i> WhatsApp Card</div>
            <div class="template-type-item" data-type="twilio/carousel" onclick="selectContentType('twilio/carousel')"><i class="bi bi-layers"></i> Carousel</div>
            <div class="template-type-item" data-type="twilio/location" onclick="selectContentType('twilio/location')"><i class="bi bi-geo-alt"></i> Location</div>
            <div class="template-type-divider"></div>
            <div class="template-type-item" data-type="baileys/buttons" onclick="selectContentType('baileys/buttons')"><i class="bi bi-hand-index-thumb"></i> Baileys Buttons</div>
            <div class="template-type-item" data-type="baileys/list" onclick="selectContentType('baileys/list')"><i class="bi bi-list-task"></i> Baileys List</div>
            <div class="template-type-item" data-type="baileys/template" onclick="selectContentType('baileys/template')"><i class="bi bi-file-earmark-code"></i> Baileys Template</div>
            <div class="template-type-item" data-type="baileys/sticker" onclick="selectContentType('baileys/sticker')"><i class="bi bi-stickies"></i> Baileys Sticker</div>
          </div>
        </div>
      </div>
      <div class="col-md-5 border-end pe-3">
        <div id="tbConfigArea">
          <!-- Dynamic config fields rendered by JS -->
          <p class="text-muted small">Select a content type to configure</p>
        </div>
        <div id="tbActionsArea" class="mt-2" style="display:none">
          <hr />
          <label class="form-label small fw-bold">Actions / Buttons</label>
          <div id="tbActionList"></div>
          <button class="btn btn-outline-secondary btn-sm mt-1" onclick="addAction()"><i class="bi bi-plus-lg"></i> Add Action</button>
        </div>
        <div id="tbItemsArea" class="mt-2" style="display:none">
          <hr />
          <label class="form-label small fw-bold">Items</label>
          <div id="tbItemList"></div>
          <button class="btn btn-outline-secondary btn-sm mt-1" onclick="addListItem()"><i class="bi bi-plus-lg"></i> Add Item</button>
        </div>
        <div id="tbCardsArea" class="mt-2" style="display:none">
