@* Inbox Panel *@
<div class="panel active" id="panel-inbox">
  <div class="inbox-layout">
    <div class="inbox-sidebar" id="inboxSidebar">
      <div class="p-2 border-bottom"><input type="text" class="form-control form-control-sm" placeholder="Search conversations..." oninput="filterInbox(this.value)" /></div>
      <div class="scroll-y" id="inboxList"></div>
    </div>
    <div class="inbox-main" id="inboxMain">
      <div id="inboxHeader" class="p-3 border-bottom d-none">
        <div class="d-flex justify-content-between align-items-center">
          <div class="d-flex align-items-center gap-2">
            <span id="inboxContactAvatar"></span>
            <div><strong id="inboxContactName"></strong><br /><small class="text-secondary" id="inboxContactInfo"></small><br /><small class="text-success" id="inboxContactStatus"></small></div>
          </div>
          <div class="d-flex gap-1">
            <button class="btn btn-outline-secondary btn-sm" onclick="showGroupInfo()" title="Group info"><i class="bi bi-people"></i></button>
            <button class="btn btn-outline-secondary btn-sm" onclick="blockCurrentContact()" title="Block"><i class="bi bi-slash-circle"></i></button>
            <button class="btn btn-outline-secondary btn-sm" onclick="showAssignModal()"><i class="bi bi-person-plus"></i></button>
            <button class="btn btn-outline-secondary btn-sm d-md-none" onclick="toggleInboxSidebar()"><i class="bi bi-arrow-left"></i></button>
          </div>
        </div>
      </div>
      <div class="scroll-y p-3 d-flex flex-column" id="inboxMessages">
        <div class="text-center text-secondary mt-5"><i class="bi bi-chat-square-text fs-1 d-block mb-2"></i><p>Select a conversation</p></div>
      </div>
      <div id="attachmentPreview">
        <div id="attachPreviewThumb"></div>
        <div class="preview-info" id="attachPreviewInfo"></div>
        <button class="preview-remove" onclick="clearAttachmentPreview()"><i class="bi bi-x-lg"></i></button>
      </div>
      <div id="inboxInput" class="p-3 border-top d-none" style="position:relative">
        <div id="replyBar" class="reply-bar d-none">
          <div class="reply-bar-content">
            <div class="reply-bar-indicator"></div>
            <div class="reply-bar-preview">
              <span class="reply-bar-label">Reply to</span>
              <span id="replyBarPreview" class="reply-bar-text"></span>
            </div>
          </div>
          <button class="btn btn-sm btn-link text-secondary reply-bar-close" onclick="cancelReply()"><i class="bi bi-x"></i></button>
        </div>
        <div class="d-flex align-items-center gap-1">
          <button class="attach-btn" onclick="toggleAttachMenu()" title="Attach"><i class="bi bi-paperclip"></i></button>
          <div class="attach-menu" id="attachMenu">
            <button class="attach-menu-item" onclick="triggerFilePicker('image')"><i class="bi bi-image" style="color:#25D366"></i> Photos & Images</button>
            <button class="attach-menu-item" onclick="triggerFilePicker('video')"><i class="bi bi-film" style="color:#0088cc"></i> Video</button>
            <button class="attach-menu-item" onclick="triggerFilePicker('audio')"><i class="bi bi-music-note-beamed" style="color:#E4405F"></i> Audio</button>
            <button class="attach-menu-item" onclick="triggerFilePicker('document')"><i class="bi bi-file-earmark" style="color:#fd7e14"></i> Document</button>
            <div class="attach-menu-divider"></div>
            <button class="attach-menu-item" onclick="showContactModal()"><i class="bi bi-person-plus" style="color:#075e54"></i> Contact</button>
            <button class="attach-menu-item" onclick="showPollModal()"><i class="bi bi-bar-chart" style="color:#667781"></i> Poll</button>
            <button class="attach-menu-item" onclick="showStatusModal()"><i class="bi bi-stars" style="color:#25D366"></i> Status</button>
          </div>
          <input type="file" id="fileInput" style="display:none" onchange="handleFileSelected(event)" />
          <input type="text" class="form-control" id="msgInput" placeholder="Type a message..." onkeydown="if(event.key==='Enter') sendInboxMsg()" onkeyup="onTyping()" />
          <button class="btn btn-primary" onclick="sendInboxMsg()"><i class="bi bi-send"></i></button>
        </div>
      </div>
    </div>
  </div>
</div>

