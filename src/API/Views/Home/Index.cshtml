          <div id="tbCardList"></div>
          <button class="btn btn-outline-secondary btn-sm mt-1" onclick="addCard()"><i class="bi bi-plus-lg"></i> Add Card</button>
        </div>
      </div>
      <div class="col-md-4">
        <label class="form-label small fw-bold">Preview</label>
        <div class="template-preview-bubble" id="builderPreview">
          <div class="text-muted small p-3">Configure your template to see a preview</div>
