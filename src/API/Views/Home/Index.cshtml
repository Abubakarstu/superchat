@* Settings Panel *@
<div class="panel" id="panel-settings">
  <div class="page-header"><h5 class="mb-0"><i class="bi bi-gear me-2"></i>Settings</h5></div>
  <div class="page-body">
    <div class="row g-4">
      <div class="col-md-6">
        <div class="stat-card mb-3"><h6>AI Configuration</h6>
          <div class="mb-2"><label class="form-label small">Provider</label><select class="form-select form-select-sm" id="sProvider" onchange="toggleOllamaUrl()"><option value="ollama">Ollama (Free, Local)</option><option value="claude">Claude (API key)</option><option value="openai">OpenAI (API key)</option></select></div>
          <div class="mb-2" id="ollamaUrlGroup"><label class="form-label small">Ollama Base URL</label><input type="text" class="form-control form-control-sm" id="sOllamaUrl" placeholder="http://localhost:11434" /></div>
          <div class="mb-2"><label class="form-label small">Model</label><input type="text" class="form-control form-control-sm" id="sModel" placeholder="llama3.2" /></div>
          <div class="row mb-2"><div class="col"><label class="form-label small">Temperature</label><input type="range" class="form-range" id="sTemp" min="0" max="2" step="0.1" value="0.7" oninput="this.nextElementSibling.textContent=this.value" /><small class="text-secondary">0.7</small></div><div class="col"><label class="form-label small">Max Tokens</label><input type="number" class="form-control form-control-sm" id="sMaxTokens" value="1024" /></div></div>
          <div class="mb-2"><label class="form-label small">System Prompt</label><textarea class="form-control form-control-sm" id="sPrompt" rows="3"></textarea></div>
          <button class="btn btn-primary btn-sm" onclick="saveAiSettings()"><i class="bi bi-check-lg"></i> Save</button>
        </div>
      </div>
      <div class="col-md-6">
        <div class="stat-card mb-3"><h6>WhatsApp Connection</h6>
          <div id="qrDisplay" class="text-center py-2"><div class="spinner-border text-primary" role="status"></div><p class="small text-secondary mt-2">Loading QR...</p></div>
          <button class="btn btn-outline-warning btn-sm w-100" onclick="refreshQr()"><i class="bi bi-arrow-clockwise"></i> Refresh QR</button>
        </div>
        <div class="stat-card"><h6>Web Widget</h6>
          <div class="mb-2"><label class="form-label small">Greeting</label><input type="text" class="form-control form-control-sm" id="wGreeting" /></div>
          <div class="mb-2"><label class="form-label small">Primary Color</label><input type="color" class="form-control form-control-color" id="wColor" value="#075e54" /></div>
          <button class="btn btn-primary btn-sm" onclick="saveWidget()"><i class="bi bi-check-lg"></i> Save Widget</button>
        </div>
        <div class="stat-card"><h6>WhatsApp Profile</h6>
          <div class="mb-2"><label class="form-label small">Profile Name</label><input type="text" class="form-control form-control-sm" id="sProfileName" placeholder="Your WhatsApp name" /></div>
          <div class="mb-2"><label class="form-label small">Status</label><input type="text" class="form-control form-control-sm" id="sProfileStatus" placeholder="About status" /></div>
          <div class="mb-2"><label class="form-label small">Profile Picture URL</label><input type="text" class="form-control form-control-sm" id="sProfilePicUrl" placeholder="https://example.com/photo.jpg" /></div>
          <button class="btn btn-primary btn-sm" onclick="updateWhatsAppProfile()"><i class="bi bi-check-lg"></i> Update Profile</button>
        </div>
      </div>
    </div>
  </div>
</div>

