@section Scripts {
<script>
  // SignalR connection
  const signalr = new signalR.HubConnectionBuilder().withUrl("/hubs/messages").withAutomaticReconnect().build();
  signalr.on("MessageReceived", msg => { if (currentConvId === msg.conversationId) appendMsg(msg); loadInbox(); });
  signalr.on("ConversationUpdated", () => loadInbox());
  signalr.on("MessageReacted", ({messageId,emoji}) => { if (currentConvId) selectConv(currentConvId); });
  signalr.on("MessageRead", ({messageId}) => { if (currentConvId) selectConv(currentConvId); });
  signalr.on("MessageEdited", ({messageId,content}) => {
    const el = document.getElementById("msg-"+messageId);
    if (!el) return;
    const txt = el.querySelector(".msg-text");
    if (txt) txt.textContent = content;
    const meta = el.querySelector(".msg-meta");
    if (meta && !meta.innerHTML.includes("edited")) meta.innerHTML = meta.innerHTML.replace('<i class="bi',' edited <i class="bi');
  });
  signalr.on("MessageDeleted", ({messageId}) => {
    const el = document.getElementById("msg-"+messageId);
    if (el) el.closest(".msg-wrapper")?.remove();
  });
  signalr.on("ContactTyping", ({remoteJid,isTyping}) => {
    const c = convs.find(x => x.remoteJid === remoteJid);
    if (c) { c.isTyping = isTyping; renderInbox(); }
    if (isTyping && c && currentConvId === c.id) showTyping(remoteJid);
    else if (!isTyping) hideTyping(remoteJid);
  });
  signalr.on("ContactOnline", ({remoteJid,isOnline,lastSeenAt}) => {
    const c = convs.find(x => x.remoteJid === remoteJid);
    if (c) { c.isOnline = isOnline; c.lastSeenAt = lastSeenAt; renderInbox(); if (currentConvId === c.id) selectConv(currentConvId); }
  });
  signalr.start().catch(console.error);

  // Init
  loadInbox(); checkConn();
  setInterval(checkConn, 15000);

  const panelLoaders = { "contacts":loadContacts, "campaigns":loadCampaigns, "templates":loadTemplates, "workflows":loadWorkflows, "team":loadTeam, "channels":loadChannels };
  document.querySelectorAll(".nav-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      document.querySelectorAll(".nav-btn").forEach(b => b.classList.remove("active"));
      btn.classList.add("active");
      document.querySelectorAll(".panel").forEach(p => p.classList.remove("active"));
      document.getElementById("panel-"+btn.dataset.panel).classList.add("active");
      const prevPanel = currentPanel;
      currentPanel = btn.dataset.panel;
      if (prevPanel === "settings") stopQrPolling();
      if (currentPanel === "analytics") loadAnalytics();
      if (currentPanel === "settings") { loadAiSettings(); refreshQr(); loadWidget(); }
      const p = btn.dataset.panel;
      if (panelLoaders[p]) setTimeout(panelLoaders[p], 100);
    });
  });
</script>
}
