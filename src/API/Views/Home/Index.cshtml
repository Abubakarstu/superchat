  <div class="modal-header"><h6 class="modal-title">Edit Template</h6><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
  <div class="modal-body">
    <div class="row">
      <div class="col-md-3 border-end pe-3">
        <div class="mb-3">
          <label class="form-label small fw-bold">Template Name</label>
          <input class="form-control form-control-sm" id="teName" placeholder="My Template" />
        </div>
        <div class="mb-3">
